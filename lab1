        color: #2a2a2a;
      }

      header,
      footer {
        background: #f5f5f5;
        padding: 20px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 24px;
        font-weight: bold;
        color: #000;
        text-decoration: none;
      }

      nav ul {
        list-style: none;
        display: flex;
        gap: 20px;
        margin: 0;
        padding: 0;
      }

      nav a {
        text-decoration: none;
        color: #333;
        font-weight: 500;
      }

      header ul {
        list-style: none;
        display: flex;
        gap: 15px;
        margin: 0;
        padding: 0;
      }

      #hero {
        text-align: center;
        padding: 120px 20px;
        background: #2f80ed;
        color: white;
      }

      #hero h1 {
        font-size: 42px;
        margin-bottom: 20px;
      }

      #hero button {
        padding: 12px 28px;
        font-size: 18px;
        border: none;
        background: #fff;
        color: #2f80ed;
        border-radius: 6px;
        cursor: pointer;
      }

      section {
        padding: 60px 40px;
      }

      h2 {
        text-align: center;
        margin-bottom: 40px;
        font-size: 32px;
      }

      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
      }

      li {
        max-width: 300px;
        text-align: center;
      }

      img {
        width: 100%;
        border-radius: 8px;
      }

      footer address ul {
        display: block;
      }

      footer address li {
        margin-bottom: 6px;
      }
    </style>
  </head>

